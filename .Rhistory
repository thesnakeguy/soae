result <- tryCatch(
gfw_ais_fishing_hours(
spatial_resolution  = "LOW",
temporal_resolution = res,
group_by            = group,
start_date          = glue("{year}-01-01"),
end_date            = glue("{year}-12-31"),
region              = region_id,
region_source       = "RFMO",
key                 = key
),
error = function(e) {
message(glue("    Initial call error: {conditionMessage(e)}"))
NULL
}
)
# If the first call failed (timeout / 429), poll gfw_get_last_report()
if (is.null(result) || nrow(result) == 0) {
message(glue("    Initial call returned no data. ",
"Polling gfw_get_last_report() (max {max_retries} tries)..."))
for (attempt in seq_len(max_retries)) {
message(glue("    Waiting {wait_sec} s before attempt {attempt}..."))
Sys.sleep(wait_sec)
result <- tryCatch(
gfw_get_last_report(key = key),
error = function(e) {
message(glue("    Attempt {attempt} failed: {conditionMessage(e)}"))
NULL
}
)
# Accept result only if it has actual data rows
if (!is.null(result) && is.data.frame(result) && nrow(result) > 0) {
message(glue("    Success on attempt {attempt}: {nrow(result)} rows."))
break
}
}
}
# Final guard: return NULL rather than an empty frame so compact() drops it
if (is.null(result) || !is.data.frame(result) || nrow(result) == 0) {
warning(glue("Could not retrieve data for {year}. Skipping."))
return(NULL)
}
result
}
# ── Disk cache ─────────────────────────────────────────────────────────────────
# Cache stores the raw combined data frame. Delete the file to force a refresh.
cache_heatmap <- "cache_heatmap_data.rds"
if (file.exists(cache_heatmap)) {
existing <- readRDS(cache_heatmap)
# VALIDATE the cache — reject if empty (was written from a failed fetch)
if (nrow(existing) == 0 || ncol(existing) == 0) {
message("Cache is empty or corrupt — deleting and re-fetching.")
file.remove(cache_heatmap)
} else {
message(glue("Valid cache found ({nrow(existing)} rows). Loading."))
heatmap_raw <- existing
}
}
if (!exists("heatmap_raw")) {
message("Fetching heatmap data from GFW API (one call per year)...")
raw_list <- map(
HEATMAP_YEARS,
~ fetch_year_robust(as.vector(.x), region_id = CCAMLR_ID, key = key)
)
heatmap_raw <- map2(raw_list, HEATMAP_YEARS, function(df, yr) {
if (is.null(df)) return(NULL)
df |> mutate(year = as.integer(yr))
}) |>
compact() |>
bind_rows()
if (nrow(heatmap_raw) == 0) stop("All year fetches failed. Check your API token and connection.")
saveRDS(heatmap_raw, cache_heatmap)
message(glue("Heatmap data cached: {nrow(heatmap_raw)} rows -> {cache_heatmap}"))
}
#| label: setup
# ── Package loading ────────────────────────────────────────────────────────────
# Install once if needed:
# install.packages(c("gfwr", "tidyverse", "sf", "scico",
#                    "patchwork", "ggrepel", "rnaturalearth",
#                    "rnaturalearthdata", "glue"))
library(gfwr)
library(tidyverse)
library(sf)
library(scico)
library(patchwork)
library(ggrepel)
library(rnaturalearth)
library(rnaturalearthdata)
library(glue)
library(stringr)
# ── Authentication ─────────────────────────────────────────────────────────────
# Add to ~/.Renviron:  GFW_TOKEN=your_token_here
# Then restart R. Obtain a free token at https://globalfishingwatch.org/our-apis/
key <- gfw_auth()
# ── Region: CCAMLR convention area ────────────────────────────────────────────
# Look up the numeric CCAMLR region id:
ccamlr_id <- gfw_region_id(region = "CCAMLR", region_source = "RFMO")
message("CCAMLR region id: ", ccamlr_id$id[1])
CCAMLR_ID <- ccamlr_id$id[1]   # numeric id used in all API calls
# ── Time-window parameters ────────────────────────────────────────────────────
CURRENT_YEAR  <- 2025
HEATMAP_YEARS <- (CURRENT_YEAR - 9):CURRENT_YEAR   # 5 most recent full years
TREND_START   <- HEATMAP_YEARS[1]
# ── gfwr column name constants ────────────────────────────────────────────────
# The API always returns these exact names (with spaces):
COL_LAT   <- "Lat"
COL_LON   <- "Lon"
COL_TIME  <- "Time Range"
COL_HOURS <- "Apparent Fishing Hours"
# ── Shared plot theme ──────────────────────────────────────────────────────────
theme_antarctic <- function() {
theme_minimal(base_size = 12) +
theme(
plot.title       = element_text(face = "bold", size = 14),
plot.subtitle    = element_text(colour = "grey40", size = 11),
plot.caption     = element_text(colour = "grey55", size = 8,
hjust = 0, margin = margin(t = 8)),
legend.position  = "right",
panel.grid.minor = element_blank(),
panel.grid.major = element_line(colour = "grey90", linewidth = 0.3),
strip.text       = element_text(face = "bold", size = 11)
)
}
GFW_CAPTION <- paste0(
"Data source: Global Fishing Watch (globalfishingwatch.org) — ",
"AIS-based apparent fishing effort (public-global-fishing-effort:v3.0)"
)
#| label: fetch-heatmap-data
## Data retrieval
# ── Robust single-year fetch with get_last_report() fallback ──────────────────
#
# Large regional queries sometimes trigger an HTTP 524 timeout on the first
# call. When this happens, the API continues processing the report server-side.
# gfw_get_last_report() polls for and retrieves that completed report.
# We retry up to MAX_RETRIES times with a WAIT_SEC pause between attempts.
fetch_year_robust <- function(year, region_id, key,
group       = "GEARTYPE",
res         = "YEARLY",
max_retries = 5,
wait_sec    = 90) {
message(glue("  Fetching {year} [{group} / {res}]..."))
result <- tryCatch(
gfw_ais_fishing_hours(
spatial_resolution  = "LOW",
temporal_resolution = res,
group_by            = group,
start_date          = glue("{year}-01-01"),
end_date            = glue("{year}-12-31"),
region              = region_id,
region_source       = "RFMO",
key                 = key
),
error = function(e) {
message(glue("    Initial call error: {conditionMessage(e)}"))
NULL
}
)
# If the first call failed (timeout / 429), poll gfw_get_last_report()
if (is.null(result) || nrow(result) == 0) {
message(glue("    Initial call returned no data. ",
"Polling gfw_get_last_report() (max {max_retries} tries)..."))
for (attempt in seq_len(max_retries)) {
message(glue("    Waiting {wait_sec} s before attempt {attempt}..."))
Sys.sleep(wait_sec)
result <- tryCatch(
gfw_get_last_report(key = key),
error = function(e) {
message(glue("    Attempt {attempt} failed: {conditionMessage(e)}"))
NULL
}
)
# Accept result only if it has actual data rows
if (!is.null(result) && is.data.frame(result) && nrow(result) > 0) {
message(glue("    Success on attempt {attempt}: {nrow(result)} rows."))
break
}
}
}
# Final guard: return NULL rather than an empty frame so compact() drops it
if (is.null(result) || !is.data.frame(result) || nrow(result) == 0) {
warning(glue("Could not retrieve data for {year}. Skipping."))
return(NULL)
}
result
}
# ── Disk cache ─────────────────────────────────────────────────────────────────
# Cache stores the raw combined data frame. Delete the file to force a refresh.
cache_heatmap <- "cache_heatmap_data.rds"
if (file.exists(cache_heatmap)) {
existing <- readRDS(cache_heatmap)
# VALIDATE the cache — reject if empty (was written from a failed fetch)
if (nrow(existing) == 0 || ncol(existing) == 0) {
message("Cache is empty or corrupt — deleting and re-fetching.")
file.remove(cache_heatmap)
} else {
message(glue("Valid cache found ({nrow(existing)} rows). Loading."))
heatmap_raw <- existing
}
}
if (!exists("heatmap_raw")) {
message("Fetching heatmap data from GFW API (one call per year)...")
raw_list <- map(
HEATMAP_YEARS,
~ fetch_year_robust(as.vector(.x), region_id = CCAMLR_ID, key = key)
)
heatmap_raw <- map2(raw_list, HEATMAP_YEARS, function(df, yr) {
if (is.null(df)) return(NULL)
df |> mutate(year = as.integer(yr))
}) |>
compact() |>
bind_rows()
if (nrow(heatmap_raw) == 0) stop("All year fetches failed. Check your API token and connection.")
saveRDS(heatmap_raw, cache_heatmap)
message(glue("Heatmap data cached: {nrow(heatmap_raw)} rows -> {cache_heatmap}"))
}
glimpse(heatmap_raw)
list.files()
